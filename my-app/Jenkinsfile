pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/freak-18/exp5.git'
            }
        }

        stage('Build') {
            steps {
                dir('my-app') {
                    bat 'mvn clean compile'
                }
            }
        }

        stage('Test') {
            steps {
                dir('my-app') {
                    bat 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('my-app') {
                    bat 'mvn package'
                }
            }
        }
    }

    post {
        success {
            echo 'Build Successful!'
        }
        failure {
            echo 'Build Failed!'
        }
    }
}
